# Secrets — never commit
.env
devices.json
tinytuya.json

# Webapp secrets + per-machine generated artifacts (public repo!)
# Wildcard covers every real config file; negation keeps the committed samples.
config/*.json
!config/*.sample.json
webapp/certificates/
webapp/icloud_session/
webapp/icloud_session_2/
webapp/*.log
logs/
# Energy-history store (server-side SQLite; per-machine runtime data)
webapp/*.sqlite3
webapp/*.sqlite3-*

# Pasted-image / scratch temp dir (e.g. screenshots dropped into chat) —
# never commit (public repo).
.launcher-tmp/

# Camera-spike captures (issue #89): snapshots / clips grabbed from the camera
# can reveal the home/location — never commit (public repo).
webapp/camera_captures/

# Machine-local heavy deps & runtime data — co-located inside the repo so
# nothing is scattered outside it, but never committed (HA OS vhdx images under
# _local/vm/, the portable NUT install + its UPS state dirs under _local/nut/).
# See src/ups_client.py for the NUT paths.
_local/

# Virtual env
.venv/
venv/

# Python
__pycache__/
*.pyc
*.py[cod]
*.egg-info/
.pytest_cache/

# Streamlit
.streamlit/secrets.toml

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
