MELCLOUD_EMAIL=your@email.com
MELCLOUD_PASSWORD=yourpassword

# SMA solar (issue #21). The energy meter / Sunny Home Manager is read over
# Speedwire with NO credentials, so the host/user/password below are only
# needed for the cloud or PV inverter login. Set SMA_CLOUD_PLANT_ID to read the
# same Sunny Portal energy-balance values shown in the SMA Energy app. Leave it
# blank to use local LAN reads only. Leave SMA_INVERTER_HOST blank to read the
# meter only (grid import/export); set it to the inverter's LAN IP once known.
# For older/local Speedwire inverters, set
# SMA_INVERTER_ACCESS_METHOD=speedwireinvV2 and use a local inverter password
# in SMA_INVERTER_PASSWORD (max 12 chars), not the SMA cloud password.
SMA_CLOUD_PLANT_ID=
# Discard a cloud point older than this many seconds (default 900) and fall
# through to the live local sources, so a frozen Sunny Portal value can't
# flat-line the live chart (issue #94).
SMA_CLOUD_MAX_STALENESS_S=
SMA_INVERTER_HOST=
SMA_INVERTER_ACCESS_METHOD=ennexos
SMA_INVERTER_GROUP=user
SMA_INVERTER_PASSWORD=
SMA_USER=your@email.com
SMA_PASSWORD=yourpassword

# Tuya / Smart Life bootstrap only. Runtime control is local LAN via
# gitignored devices.json; these values are only needed if you run the
# TinyTuya wizard again to fetch device IDs and local keys.
TUYA_API_KEY=your-access-id
TUYA_API_SECRET=your-access-secret
TUYA_REGION=eu

# Elgato Key Light / Key Light Air / Light Strip (issue #124). Runtime control
# is local LAN HTTP. Leave blank to try Bonjour/mDNS discovery; set one or more
# host[:port] values if discovery is blocked (comma-separated).
ELGATO_LIGHT_HOSTS=

# RISCO Cloud alarm (issue #43) - the Security tab. Username + password are your
# RISCO Cloud login; the PIN is the panel code used to arm/disarm. Recommended:
# a dedicated, non-owner RISCO sub-account for the app so it doesn't knock your
# phone's session out (RISCO restricts concurrent logins).
RISCO_USERNAME=your@email.com
RISCO_PASSWORD=yourpassword
RISCO_PIN=0000
# Optional group letters (A-D) used only to label a partially-set state more
# precisely when the panel reports group data.
RISCO_PERIMETER_GROUP=
RISCO_PARTIAL_GROUP=

# iCloud Find My presence spike (issue #86). Used only by
# src.list_presence to prove whether Find My location reads are viable for a
# future HVAC presence trigger. Session cookies are live Apple auth material
# and must remain in the gitignored ICLOUD_SESSION_DIR.
ICLOUD_EMAIL=your@email.com
ICLOUD_PASSWORD=yourpassword
ICLOUD_SESSION_DIR=webapp/icloud_session
PRESENCE_HOME_RADIUS_M=200
# Optional second Apple Account (issue #478). Family Sharing only exposes one
# account's own devices plus its family members, so a phone on a different Apple
# ID needs its own login to appear. Set both _2 vars to merge that account's
# Find My devices into the same snapshot; leave them blank for a single account.
# ICLOUD_EMAIL_2=second@email.com
# ICLOUD_PASSWORD_2=secondpassword
# ICLOUD_SESSION_DIR_2=webapp/icloud_session_2

# Network view spike (issue #125). Two LAN devices reached over loopback/LAN:
# the NETGEAR access point (attached-device inventory + reboot, via the Netgear
# SOAP API) and the Vodafone ZXHN F6600P router (SHA256 web login). Host values
# are the devices' LAN IPs; username/password are the web-admin logins. The AP
# username is usually "admin"; the ZTE router's is usually "user".
NETWORK_AP_HOST=192.168.0.x
NETWORK_AP_USERNAME=admin
NETWORK_AP_PASSWORD=yourpassword
# Optional: stable MAC address of the access point. When set and NETWORK_AP_HOST
# becomes stale after a DHCP change, the app looks up this MAC in the router's
# lease table and retries the AP connection at the discovered IP (issue #150).
NETWORK_AP_MAC=
NETWORK_ROUTER_HOST=192.168.0.1
NETWORK_ROUTER_USERNAME=user
NETWORK_ROUTER_PASSWORD=yourpassword

# Cameras (issue #161) are NOT configured here — they live in gitignored
# config/cameras.json (copy config/cameras.sample.json). Enable ONVIF + RTSP on
# the camera first (Reolink app: Settings > Network > Advanced > Server Settings).

# Home Assistant config deploy + runtime Voice PE consumption (issues #243/#239).
# HA_URL/HA_TOKEN are shared by scripts/ha_config_sync.py and the folded Home
# card (satellite discovery, announce, and best-effort Assist trace ingestion).
# The SSH fields are used only to push this repo's voice-PE config into the HA VM's
# /config (via the Terminal & SSH add-on shell), run `ha core check`, and probe
# the conversation API. NONE of this stores real HA secrets — the live
# secrets.yaml (bearer token, voice PIN) stays on the VM and is never read,
# printed, copied, or committed. One-time bootstrap (enable the add-on, paste
# this PC's public key, expose a LAN-only port) is required first — see
# docs/voice-pe-config/README.md.
HA_SSH_HOST=192.168.0.4
HA_SSH_PORT=2222
HA_SSH_USER=root
HA_SSH_KEY=C:/Users/you/.ssh/ha_ed25519
HA_URL=http://192.168.0.4:8123
HA_TOKEN=your-long-lived-access-token

# App Launcher-compatible live transcription. The browser streams one-second
# chunks through this app to Voice Transcriber's supported session API; that app
# persists the take and reuses the already-running Whisper model. Empty disables
# push-to-talk. HA trace collection is lightweight (15 s, bounded IDs) and can be
# disabled independently for diagnostics/tests.
VOICE_TRANSCRIBER_URL=https://127.0.0.1:8443
HA_TRACE_ENABLED=1

# Hyper-V VM control (issue #240). The exact name of the Home Assistant VM as it
# appears in Hyper-V Manager / `Get-VM`. The webapp reads/starts/stops ONLY this
# VM (by name) for the Home-tab status tile — never any other VM on the host.
# Prerequisite: the tray/webapp user must be in the local "Hyper-V Administrators"
# group to start/stop it (status reads may work unprivileged). See README.
HA_VM_NAME=Home Assistant
